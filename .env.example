# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_ID=your-app-id
JWT_SECRET=generate_a_long_random_string
OWNER_OPEN_ID=owner-openid-from-oauth
# OAuth portal base URL (no trailing slash); must match your registered app.
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.example.com

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:pass@127.0.0.1:3306/visual_search

# ─── Gemini (primary: vision, refine, image gen, visual search analysis) ─────
GEMINI_API_KEY=
# Optional overrides (defaults match your deployment)
GEMINI_MODEL_TEXT=gemini-2.5-flash-lite
GEMINI_MODEL_NANO_BANANA=gemini-3-pro-image-preview
# Falls back to GEMINI_API_KEY if unset
GOOGLE_API_KEY=

# ─── Optional: other gateways (maps/data proxy, notifications, whisper) ───────
OPENAI_API_KEY=
LLM_API_BASE_URL=
# LLM_API_KEY=

SERPAPI_API_KEY=

# ─── Media ───────────────────────────────────────────────────────────────────
CLOUDINARY_URL=cloudinary://key:secret@cloud_name

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
